      "type": "table",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 14 },
      "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "gitvm-infinity" },
      "targets": [
        { "refId": "A", "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "gitvm-infinity" }, "type": "json", "source": "url", "format": "table", "url": "${portal}/api/monitoring/users?token=${token}", "url_options": { "method": "GET" }, "root_selector": "", "columns": [] }
      ]
    }
  ]
